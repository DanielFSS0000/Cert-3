    {
      "name": "Post/NewUser",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = Date.now();\r",
              "\r",
              "const dynamicName = `Usuario QA ${timestamp}`;\r",
              "const dynamicUsername = `qa_user_${timestamp}`;\r",
              "const dynamicEmail = `qa_user_${timestamp}@test.com`;\r",
              "\r",
              "pm.collectionVariables.set(\"dynamic_name\", dynamicName);\r",
              "pm.collectionVariables.set(\"dynamic_username\", dynamicUsername);\r",
              "pm.collectionVariables.set(\"dynamic_email\", dynamicEmail);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Tiempo de respuesta menor a 2000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"La respuesta es un objeto\", function () {\r",
              "    const user = pm.response.json();\r",
              "    pm.expect(user).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"El name enviado coincide con el name devuelto\", function () {\r",
              "    const user = pm.response.json();\r",
              "\r",
              "    pm.expect(user.name).to.eql(pm.collectionVariables.get(\"dynamic_name\"));\r",
              "});\r",
              "\r",
              "pm.test(\"El username enviado coincide con el username devuelto\", function () {\r",
              "    const user = pm.response.json();\r",
              "\r",
              "    pm.expect(user.username).to.eql(pm.collectionVariables.get(\"dynamic_username\"));\r",
              "});\r",
              "\r",
              "pm.test(\"El email enviado coincide con el email devuelto\", function () {\r",
              "    const user = pm.response.json();\r",
              "\r",
              "    pm.expect(user.email).to.eql(pm.collectionVariables.get(\"dynamic_email\"));\r",
              "});\r",
              "\r",
              "pm.test(\"La respuesta contiene un id generado\", function () {\r",
              "    const user = pm.response.json();\r",
              "\r",
              "    pm.expect(user).to.have.property(\"id\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{dynamic_name}}\",\r\n  \"username\": \"{{dynamic_username}}\",\r\n  \"email\": \"{{dynamic_email}}\"\r\n}",
          "options": {
            "raw": {
